# DATABASE_URL: PostgreSQL connection string.
# In Docker Compose, this defaults to the linked 'db' container.
DATABASE_URL=postgresql://postgres:postgres@db:5432/haujee

# JWT_SECRET: Secret key for signing JSON Web Tokens.
JWT_SECRET=super-secret-key-change-me

# Cloudflare R2 / S3 Storage (Required for receipt PDF storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Meta WhatsApp Cloud API (Optional for notifications)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=receipt_notification
WHATSAPP_ODF_TEMPLATE_NAME=odf_notification

# Brevo / Sendinblue (Email) (Optional for notifications)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME="Haujee Jewellery"

# GEMINI_API_KEY: Required for scanning items via AI
GEMINI_API_KEY=

# APP_URL: The base URL of your application (used for PDF links)
APP_URL=http://localhost:3000
